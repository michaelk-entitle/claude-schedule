{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "CronCreate",
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/hook.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}\"/scripts/hook.sh --event UserPromptSubmit" }
        ]
      }
    ]
  }
}
